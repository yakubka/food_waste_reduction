# ── Backend (FastAPI) ──────────────────────────────────────────────────────────
DEBUG=false

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=campuseats
DB_USER=postgres
DB_PASSWORD=your_db_password

# Redis
REDIS_URL=redis://localhost:6379

# MQTT (IoT scales)
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883

# JWT
JWT_SECRET=your_super_secret_key_here_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS
FRONTEND_URL=http://localhost:3000

# ── ML Service ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:your_db_password@localhost/campuseats
